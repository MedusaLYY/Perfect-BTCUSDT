{
  "random_seed": 42,
  "timezone": "UTC",
  "datasets": {
    "klines": {
      "candidate_paths": [
        "data/raw/BTCUSDT_spot_klines_1m.csv",
        "data/raw/binance/BTCUSDT_spot_klines_1m.csv"
      ]
    },
    "agg_trades": {
      "candidate_paths": [
        "data/raw/BTCUSDT_spot_agg_trades.csv",
        "data/raw/binance/BTCUSDT_spot_agg_trades.csv"
      ]
    }
  },
  "outputs": {
